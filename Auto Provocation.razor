# ============================================
#   PRIME VARS / RESET
# ============================================
@setvar! mobOne 0
@setvar! mobTwo 0
@setvar! saveMob 0
@setvar! discordTarget 0
@setvar! loopDone 0
@setvar! badTarget 0

@setvar! isProvoked 0
@setvar! isBreak 0
@setvar! isDiscorded 0

@setvar! skipDisco 0

# ============================================
#   INITIAL TARGET
# ============================================
hotkey 'target closest non-friendly monster'
@setvar! myKillTarget lasttarget
@setvar! firstTarget myKillTarget

if insysmsg "no one matching"
    overhead "Nothing to attack" 34
    @clearignore 
    script "stayalive2"
endif

# ============================================
#   TARGET SCAN LOOP (NO DISTANCE BANDS)
# ============================================
while loopDone = 0

    if hits < 30
        overhead "GTFO!!!"
        @clearignore
        script "stayalive2"
    endif

    # Only consider mobs within 12 tiles
    if find myKillTarget ground -1 -1 12

        getlabel myKillTarget desc2

        @setvar! isProvoked 0
        @setvar! isBreak 0
        @setvar! isDiscorded 0

        if "provoked" in desc2
            @setvar! isProvoked 1
        endif
        if "break" in desc2
            @setvar! isBreak 1
        endif
        if discordTarget = 0
        endif


        if isBreak = 1
            overhead desc2 66 myKillTarget
        endif
        

        # -----------------------------------------
        # CLEAN PROVOKE CANDIDATES
        # -----------------------------------------
        if isProvoked = 0 and isBreak = 0
            # mobOne = first clean candidate
            if mobOne = 0
                @setvar! mobOne myKillTarget
            # -----------------------------------------
            # Provoke EARLY EXIT
            # -----------------------------------------
            elseif mobTwo = 0 and myKillTarget != mobOne
                @setvar! mobTwo myKillTarget
                @setvar! loopDone 1
            endif
        endif
        
        
        # -----------------------------------------
        # Provoke EARLY EXIT NO CD TAKE ANYTHING, supercedes fallback logic
        # -----------------------------------------
        if isBreak = 0 and mobOne != 0 and mobTwo = 0 and myKillTarget != mobOne and not cooldown "Provocation" and loopDone = 0
            @setvar! mobTwo myKillTarget
            @setvar! loopDone 1
        endif
        
        # -----------------------------------------
        # Fallback logic
        # -----------------------------------------
        if saveMob = 0 and isBreak = 0 and loopDone = 0
            @setvar! saveMob myKillTarget
        endif
        
        # -----------------------------------------
        # DISCORD 
        # -----------------------------------------
        if discordTarget = 0 and loopDone = 0
            if "discord" in desc2
                @setvar! isDiscorded 1
            endif
            if isDiscorded = 0
                @setvar! discordTarget myKillTarget
                # If provoke is impossible, exit early
                if cooldown "Provocation" > 5100
                    @setvar! loopDone 1
                endif
            endif
        endif
    endif
    
    

    if loopDone = 0
        # Move to next mob
        hotkey 'Next Non-Friendly Monster Target'
        @setvar! myKillTarget lasttarget

        # Full loop complete
        if myKillTarget = firstTarget
            @setvar! loopDone 1
        endif
    endif
endwhile

# ============================================
#   FALLBACK FOR mobTwo
# ============================================
if mobTwo = 0
    if saveMob != 0 and saveMob != mobOne
        @setvar! mobTwo saveMob
    endif
endif

# ============================================
#   EXIT IF NO TARGETS
# ============================================
if discordTarget = 0 and mobOne = 0
    overhead "No valid targets!" 34
    @clearignore 
    hotkey "Play Script: stayalive2"
endif

# ============================================
#   WAIT OUT COOLDOWNS
# ============================================
while cooldown "Provocation" and cooldown "Discordance"
    overhead "Cooldowns!" 34
    wait 20
    if hits < 30
        overhead "GTFO!!!"
        @clearignore 
        script "stayalive2"
    endif
endwhile

while cooldown "Skill Lockout"
    overhead "Cooldowns!" 34
    wait 20
    if hits < 30
        overhead "GTFO!!!"
        @clearignore 
        script "stayalive2"
    endif
endwhile

# ============================================
#   CLEAR CURSOR
# ============================================
if targetexists
    hotkey "Cancel Current Target"
endif

# ============================================
#   PROVOKE BLOCK
# ============================================
if cooldown "Provocation" < 1000
    if mobOne != 0

        # fallback: use saveMob if mobTwo missing
        if mobTwo = 0
            if saveMob != 0 and saveMob != mobOne
                @setvar! mobTwo saveMob
            endif
        endif

        if mobTwo != 0

            # wait for provoke if <500ms
            if cooldown "Provocation" < 500
                while cooldown "Provocation"
                    wait 20
                    if hits < 30
                        overhead "GTFO!!!"
                        @clearignore 
                        script "stayalive2"
                    endif
                endwhile
            endif

            @setvar! skipDisco 1
            overhead "Provoking!"
            useskill 'Provocation'
            wft 550
            target mobOne
            if insysmsg "cannot be seen"
                ignore mobOne
                @setvar! badTarget 1
            endif
            wft 550
            target mobTwo
            if insysmsg "cannot be seen"
                ignore mobTwo
                @setvar! badTarget 1
            endif
        endif
    endif
endif

# ============================================
#   DISCORD BLOCK
# ============================================
if skipDisco = 0
    if not cooldown "Discordance"
        if discordTarget != 0
            overhead "Discordance!"
            useskill 'Discordance'
            wft 250

            if insysmsg "must wait a moment"
                useskill 'Discordance'
                wft 550
            endif

            target discordTarget
            if insysmsg "cannot be seen"
                ignore myKillTarget
                @setvar! badTarget 1
            endif
        endif
    endif
endif


# ============================================
#   FINAL EXIT / RESET LOGIC
# ============================================
if cooldown "Bard Reset"
    cooldown "Bard Reset" 0
    overhead "<<< GOT A RESET >>>" 33
    @clearignore 
    hotkey "Play Script: Auto Provocation"
elseif badTarget = 1
    cooldown "Bard Reset" 0
    overhead "<<< BAD TARGET REDO >>>" 33
    hotkey "Play Script: Auto Provocation"
else
    @clearignore 
    hotkey "Play Script: stayalive2"
endif