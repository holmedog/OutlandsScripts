# Prime vars
@setvar! mobOne 0
@setvar! mobTwo 0
@setvar! saveMob 0
@setvar! discordTarget 0
@setvar! loopDone 0

# Wait out cooldowns
while cooldown "Provocation" and cooldown "Discordance"
    overhead "Cooldowns!" 34
    getlabel backpack ping
    if hits < 30
        overhead "GTFO!!!"
        script "stayalive2"
    endif
endwhile

# Get initial target
hotkey 'target closest non-friendly monster'
@setvar! myKillTarget lasttarget
@setvar! firstTarget myKillTarget
getlabel backpack ping
if insysmsg "no one matching"
    overhead "Nothing to attack" 34
    script "stayalive2"
endif


# ============================
#   TARGET SCAN LOOP
# ============================
while loopDone = 0

    if hits < 30
        overhead "GTFO!!!"
        script "stayalive2"
    endif

    if find myKillTarget ground -1 -1 11

        getlabel myKillTarget desc2
        overhead desc2 66 myKillTarget

        # -------------------------
        # PROVOCATION LOGIC
        # -------------------------
        # Valid provoke target = NOT provoked AND NOT break
        if "provoked" in desc2
            # skip provoke
        else
            if "break" in desc2
                # skip provoke
            elseif "pacified" in desc2
                # skip provoke
            else
                if mobOne = 0
                    @setvar! mobOne myKillTarget
                else
                    if mobTwo = 0
                        @setvar! mobTwo myKillTarget
                        @setvar! loopDone 1
                    endif
                endif
            endif
        endif

        # -------------------------
        # DISCORD LOGIC
        # -------------------------
        # Valid discord target = NOT discord (break allowed)
        if discordTarget = 0
            if "discord" in desc2
                # skip
            else
                @setvar! discordTarget myKillTarget
            endif
        endif

        # -------------------------
        # SAVE FALLBACK PROVOKE TARGET
        # -------------------------
        # Only save if NOT break
        if saveMob = 0
            if "break" in desc2
                # skip
            else
                @setvar! saveMob myKillTarget
            endif
        endif

    endif

    # Next target
    hotkey 'Next Non-Friendly Monster Target'
    @setvar! myKillTarget lasttarget

    if myKillTarget = firstTarget
        @setvar! loopDone 1
    endif

endwhile

# ----------------------------
# PROVOKE BLOCK
# ----------------------------
@setvar! skipDisco 0

# Cooldowns first
if not cooldown "Provocation"
    if not cooldown "Skill Lockout"
        # Must have at least one clean provoke target
        if mobOne != 0
            # CASE 1: Two clean provoke targets
            if mobTwo != 0

                overhead "Provoking!"
                useskill 'Provocation'
                wft 500

                if targetexists
                    @setvar! skipDisco 1
                    target mobOne
                    wft 500
                    target mobTwo
                endif
            else
                # CASE 2: Fallback provoke
                # Only valid if saveMob exists AND is not mobOne
                if saveMob != 0
                    if saveMob != mobOne
                        overhead "Provoking!"
                        useskill 'Provocation'
                        wft 500

                        if targetexists
                            @setvar! skipDisco 1
                            target mobOne
                            wft 500
                            target saveMob
                        endif
                    endif
                endif
            endif
        endif
    endif
endif


# ----------------------------
# DISCORD BLOCK
# ----------------------------
if skipDisco = 0
    if not cooldown "Discordance"
        if not cooldown "Skill Lockout"
            if discordTarget != 0
                overhead "Discordance!"
                useskill 'Discordance'
                wft 500
                if targetexists
                    target discordTarget
                endif
            endif
        endif
    endif
endif

# ----------------------------
# FINAL EXIT / RESET LOGIC
# ----------------------------
getlabel backpack ping
if cooldown "Bard Reset"
    cooldown "Bard Reset" 0
    overhead "<<< GOT A RESET >>>" 33
    hotkey "Play Script: Auto Provocation"
else
    hotkey "Play Script: stayalive2"
endif