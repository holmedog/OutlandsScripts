#overhead "Chiv Buffs" 43
while targetexists 
    wait 20
endwhile

if not varexist myOverrideTarget
    #overhead "No override variable"
    setvar myOverrideTarget 0
endif

if find myOverrideTarget ground -1 -1 10 as foundTarget
    @setvar! myKillTarget myOverrideTarget 
    #overhead "Override found, going at it"
else
    hotkey 'Target Closest Non-Friendly Monster'
    @setvar! myKillTarget lasttarget 
    #overhead "No Override found, Target Closest"
endif    


#if skill 'Peacemaking' > 50
    #hotkey 'Clear Target Queue'
    #skill 'Peacemaking'
    #wft 1500
    #    target myKillTarget
#endif

if noto 'myKillTarget' != hostile 
    #overhead "STOP!" 33
    script "stayalive2"
endif
if noto 'myKillTarget' = hostile 
    attack myKillTarget 
endif

#say '[divinefury'
#wait 550
#say '[enemyofone'
#say '[consecrateweapon'

#say '[disarm'

#getlabel myKillTarget desc
#overhead desc 33
#overhead "● ▼▼ HERE ▼▼ ●" 88 myKillTarget
script "stayalive2"
 